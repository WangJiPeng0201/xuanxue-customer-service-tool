# 默认推荐用 OpenAI 兼容接口。下面是 DeepSeek 示例：
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# FreeModel 示例，如果你确认后台文档里的 Base URL 和模型名：
# OPENAI_API_KEY=你的 FreeModel Key
# OPENAI_BASE_URL=https://api.freemodel.dev
# OPENAI_MODEL=gpt-5.5
# OPENAI_WIRE_API=responses

# FreeModel VIP SG 线路示例：
# OPENAI_API_KEY=你的 FreeModel Key
# OPENAI_BASE_URL=https://vip-sg.freemodel.dev
# OPENAI_MODEL=gpt-5.5
# OPENAI_WIRE_API=responses

# 也可以用 LLM_*，含义一样：
# LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_WIRE_API=chat
